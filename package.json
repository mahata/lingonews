{
  "name": "lingonews",
  "private": true,
  "scripts": {
    "build": "esbuild app/javascript/application.tsx --bundle --sourcemap --format=esm --outdir=app/assets/builds --loader:.tsx=tsx --loader:.ts=ts",
    "build:watch": "esbuild app/javascript/application.tsx --bundle --sourcemap --format=esm --outdir=app/assets/builds --loader:.tsx=tsx --loader:.ts=ts --watch",
    "build:production": "esbuild app/javascript/application.tsx --bundle --minify --format=esm --outdir=app/assets/builds --loader:.tsx=tsx --loader:.ts=ts",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "postinstall": "if [ -d .git ]; then lefthook install; fi"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.3.0",
    "esbuild": "^0.28.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.1.6",
    "typescript": "^6.0.3"
  }
}
