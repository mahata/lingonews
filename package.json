{
  "name": "lingonews",
  "private": true,
  "scripts": {
    "build": "esbuild app/javascript/application.tsx --bundle --sourcemap --format=esm --outdir=app/assets/builds --loader:.tsx=tsx --loader:.ts=ts",
    "build:watch": "esbuild app/javascript/application.tsx --bundle --sourcemap --format=esm --outdir=app/assets/builds --loader:.tsx=tsx --loader:.ts=ts --watch",
    "build:production": "esbuild app/javascript/application.tsx --bundle --minify --format=esm --outdir=app/assets/builds --loader:.tsx=tsx --loader:.ts=ts"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.2",
    "esbuild": "^0.28.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.2"
  }
}
